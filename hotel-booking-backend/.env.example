# Server Config
PORT=5000
NODE_ENV=development

# Database
MONGODB_URI=mongodb://localhost:27017/hotel-booking
# For production use MongoDB Atlas:
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/hotel-booking

# JWT Secret (use a strong random string in production)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Seed/Admin passwords for scripts
ADMIN_SEED_PASSWORD=change-this-admin-password
STAFF_SEED_PASSWORD=change-this-staff-password

# Telegram Bot
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-from-botfather
OWNER_CHAT_ID=your-telegram-chat-id

# Chapa Payment Gateway
CHAPA_SECRET_KEY=your-chapa-secret-key-from-dashboard
CHAPA_WEBHOOK_SECRET=your-webhook-secret-hash
# For test mode, use test keys from https://dashboard.chapa.co

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Backend URL (for webhook callbacks)
BACKEND_URL=http://localhost:5000
